# Server Configuration
PORT=3000
NODE_ENV=development

# CORS (for frontend)
CORS_ORIGIN=*

# Authentication (optional - leave empty to disable)
# Generate a secure token: openssl rand -hex 32
AUTH_TOKEN=

# Decision log (permanent, timestamped record of every referee/jury decision)
# Leave empty to default to ./data/decision-log.jsonl relative to the backend's working directory
DECISION_LOG_PATH=
