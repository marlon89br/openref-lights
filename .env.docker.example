# Docker Compose Environment Variables
# Copy this file to .env.docker and customize for your deployment

# Backend Configuration
BACKEND_PORT=3000
NODE_ENV=production
CORS_ORIGIN=*

# Authentication Token (optional)
# Provides basic access control for competition use
# Leave empty to disable, or generate with: openssl rand -hex 32
# NOTE: Transmitted over HTTP - suitable for private networks only
# See README.md Security Considerations for details
AUTH_TOKEN=

# Frontend Configuration
FRONTEND_PORT=8080

# Backend URL the frontend talks to over WebSocket (baked into the frontend build - Angular has no runtime env vars)
BACKEND_URL=http://localhost:3000

# Public URL/domain the site is actually reachable at (e.g. https://meet.example.com or http://192.168.1.50:8080).
# Used to build the join links/QR codes the jury shares with referees and the display.
# Leave empty to fall back to the browser's own address bar - but that breaks QR codes/links
# if the jury happens to open the page via "localhost" instead of the real domain/IP.
FRONTEND_URL=

# Decision log: a permanent, timestamped record of every referee/jury decision
# is written to the "openref-data" Docker volume (backend/data/decision-log.jsonl),
# so it survives container recreation.
