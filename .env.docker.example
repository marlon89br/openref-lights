# Docker Compose Environment Variables
# Copy this file to .env.docker and customize for your deployment

# Backend Configuration
BACKEND_PORT=3000
NODE_ENV=production
CORS_ORIGIN=*

# Authentication Token (optional)
# Provides basic access control for competition use
# Leave empty to disable, or generate with: openssl rand -hex 32
# NOTE: Transmitted over HTTP - suitable for private networks only
# See README.md Security Considerations for details
AUTH_TOKEN=

# Frontend Configuration
FRONTEND_PORT=8080

# Decision log: a permanent, timestamped record of every referee/jury decision
# is written to the "openref-data" Docker volume (backend/data/decision-log.jsonl),
# so it survives container recreation.
